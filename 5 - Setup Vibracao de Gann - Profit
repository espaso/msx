{===========================================
  Indicador: Gann Vibration (Tempo + Preço)
  Tipo: Estratégia de Indicadores (NTSL)
  Autor: M365 Copilot (educacional)
===========================================}

Input
  // Ciclos de tempo (em candles)
  Cycle1(8), Cycle2(13), Cycle3(21), Cycle4(34),
  // Vibrações de preço (pontos/US$)
  Vib1(300.0), Vib2(500.0), Vib3(600.0), Vib4(800.0),
  // Filtros
  TolPerc(10.0),      // tolerância % para "bater" vibração
  MinATR(100.0),      // piso de volatilidade (ajuste por ativo)
  UseVWAP(True),
  UseMA21(True);

Var
  lastPivotPrice : Float;
  lastPivotDir   : Integer; // +1 topo, -1 fundo
  barsFromPivot  : Integer;
  priceMoveAbs   : Float;

  atr14, vwapVal, ma21, volMA20 : Float;
  inPriceVibration, inTimeCycle : Boolean;
  syncCondition, atrFilter, volFilter, vwapFilter, ma21Filter : Boolean;
  revBull, revBear, longSignal, shortSignal : Boolean;

  // util
  tol1, tol2, tol3, tol4 : Float;

Begin
  // Indicadores básicos
  atr14    := ATR(14);
  vwapVal  := VWAP(10);
  ma21     := Media(Close, 21);
  volMA20  := Media(Volume, 20);

  // --- DETECÇÃO DE PIVÔ SIMPLES (pivô simétrico curto) ---
  if (High[1] > High[2]) and (High[1] > High) then
  begin
    lastPivotPrice := High[1];
    lastPivotDir   := +1;     // topo → tendência posterior de baixa
    barsFromPivot  := 0;
  end
  else if (Low[1] < Low[2]) and (Low[1] < Low) then
  begin
    lastPivotPrice := Low[1];
    lastPivotDir   := -1;     // fundo → tendência posterior de alta
    barsFromPivot  := 0;
  end
  else
    barsFromPivot  := barsFromPivot + 1;

  // Amplitude desde o pivô
  if lastPivotDir = +1 then
    priceMoveAbs := Abs(lastPivotPrice - Close)
  else if lastPivotDir = -1 then
    priceMoveAbs := Abs(Close - lastPivotPrice)
  else
    priceMoveAbs := 0;

  // --- TESTE DE VIBRAÇÕES DE PREÇO (± tolerância %) ---
  tol1 := Vib1 * (TolPerc/100.0);
  tol2 := Vib2 * (TolPerc/100.0);
  tol3 := Vib3 * (TolPerc/100.0);
  tol4 := Vib4 * (TolPerc/100.0);

  inPriceVibration :=
       (Abs(priceMoveAbs - Vib1) <= tol1)
    or (Abs(priceMoveAbs - Vib2) <= tol2)
    or (Abs(priceMoveAbs - Vib3) <= tol3)
    or (Abs(priceMoveAbs - Vib4) <= tol4);

  // --- TESTE DE CICLOS DE TEMPO (± 1 candle) ---
  inTimeCycle :=
       (barsFromPivot = Cycle1) or (barsFromPivot = Cycle1-1) or (barsFromPivot = Cycle1+1)
    or (barsFromPivot = Cycle2) or (barsFromPivot = Cycle2-1) or (barsFromPivot = Cycle2+1)
    or (barsFromPivot = Cycle3) or (barsFromPivot = Cycle3-1) or (barsFromPivot = Cycle3+1)
    or (barsFromPivot = Cycle4) or (barsFromPivot = Cycle4-1) or (barsFromPivot = Cycle4+1);

  // --- CANDLE DE REVERSÃO (força contrária + range ≥ ATR) ---
  revBull := (lastPivotDir = +1) and (Close > Open) and ((High - Low) >= atr14);
  revBear := (lastPivotDir = -1) and (Close < Open) and ((High - Low) >= atr14);

  // --- FILTROS DE CONTEXTO ---
  atrFilter  := atr14 >= MinATR;
  volFilter  := Volume > volMA20;
  if UseVWAP then
    vwapFilter := (lastPivotDir = +1) ? (Close < vwapVal) : (Close > vwapVal)
  else
    vwapFilter := True;

  if UseMA21 then
    ma21Filter := (lastPivotDir = +1) ? (Close < ma21) : (Close > ma21)
  else
    ma21Filter := True;

  // --- SINAL FINAL ---
  syncCondition := inPriceVibration and inTimeCycle;
  longSignal  := syncCondition and revBull  and atrFilter and volFilter and vwapFilter and ma21Filter;
  shortSignal := syncCondition and revBear  and atrFilter and volFilter and vwapFilter and ma21Filter;

  // --- PLOTS E ALERTAS ---
  Plot(Close); // preço
  if longSignal  then Alert($00FF00); // verde
  if shortSignal then Alert($FF0000); // vermelho

End.

