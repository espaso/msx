{=============================================================
  Estratégia de Execução: Gann Vibration (Tempo + Preço)
  Tipo: Estratégia de Execução (Backtest/Automação)
  Autor: M365 Copilot (educacional)
==============================================================}

Input
  // --- Presets de Ciclo e Vibração ---
  Cycle1(8), Cycle2(13), Cycle3(21), Cycle4(34),
  Vib1(300.0), Vib2(500.0), Vib3(600.0), Vib4(800.0),
  TolPerc(10.0), MinATR(100.0),

  // --- Filtros ---
  UseVWAP(True), UseMA21(True),

  // --- Execução ---
  Qty(1),                 // contratos
  RTarget(1.0),           // alvo em múltiplos do risco (1.0 = 1:1)
  StopMode(1),            // 1=candle de reversão; 2=metade da vibração "batida"
  MaxTradesPerDay(3);

Var
  // Núcleo (mesmo do Indicador)
  lastPivotPrice : Float;
  lastPivotDir   : Integer;
  barsFromPivot  : Integer;
  priceMoveAbs   : Float;
  atr14, vwapVal, ma21, volMA20 : Float;
  inPriceVibration, inTimeCycle, syncCondition : Boolean;
  revBull, revBear, atrFilter, volFilter, vwapFilter, ma21Filter : Boolean;
  tol1, tol2, tol3, tol4 : Float;

  // Execução
  tradesToday : Integer;
  entryPrice, stopPrice, targetPrice : Float;
  canEnter : Boolean;

  // Bookkeeping simples por dia
  currentDate : Integer;

Begin
  // Reset contador de trades por dia
  if Date <> currentDate then
  begin
    currentDate := Date;
    tradesToday := 0;
  end;

  // Indicadores/Técnicos
  atr14    := ATR(14);
  vwapVal  := VWAP(10);
  ma21     := Media(Close, 21);
  volMA20  := Media(Volume, 20);

  // Pivô simples
  if (High[1] > High[2]) and (High[1] > High) then
  begin
    lastPivotPrice := High[1]; lastPivotDir := +1; barsFromPivot := 0;
  end
  else if (Low[1] < Low[2]) and (Low[1] < Low) then
  begin
    lastPivotPrice := Low[1];  lastPivotDir := -1; barsFromPivot := 0;
  end
  else
    barsFromPivot := barsFromPivot + 1;

  // Amplitude
  if lastPivotDir = +1 then priceMoveAbs := Abs(lastPivotPrice - Close)
  else if lastPivotDir = -1 then priceMoveAbs := Abs(Close - lastPivotPrice)
  else priceMoveAbs := 0;

  // Vibrações (± tolerância %)
  tol1 := Vib1 * (TolPerc/100.0);
  tol2 := Vib2 * (TolPerc/100.0);
  tol3 := Vib3 * (TolPerc/100.0);
  tol4 := Vib4 * (TolPerc/100.0);

  inPriceVibration :=
       (Abs(priceMoveAbs - Vib1) <= tol1)
    or (Abs(priceMoveAbs - Vib2) <= tol2)
    or (Abs(priceMoveAbs - Vib3) <= tol3)
    or (Abs(priceMoveAbs - Vib4) <= tol4);

  // Ciclos (±1)
  inTimeCycle :=
       (barsFromPivot = Cycle1) or (barsFromPivot = Cycle1-1) or (barsFromPivot = Cycle1+1)
    or (barsFromPivot = Cycle2) or (barsFromPivot = Cycle2-1) or (barsFromPivot = Cycle2+1)
    or (barsFromPivot = Cycle3) or (barsFromPivot = Cycle3-1) or (barsFromPivot = Cycle3+1)
    or (barsFromPivot = Cycle4) or (barsFromPivot = Cycle4-1) or (barsFromPivot = Cycle4+1);

  // Reversão + filtros
  revBull   := (lastPivotDir = +1) and (Close > Open) and ((High - Low) >= atr14);
  revBear   := (lastPivotDir = -1) and (Close < Open) and ((High - Low) >= atr14);
  atrFilter := atr14 >= MinATR;
  volFilter := Volume > volMA20;

  if UseVWAP then
    vwapFilter := (lastPivotDir = +1) ? (Close < vwapVal) : (Close > vwapVal)
  else
    vwapFilter := True;

  if UseMA21 then
    ma21Filter := (lastPivotDir = +1) ? (Close < ma21) : (Close > ma21)
  else
    ma21Filter := True;

  syncCondition := inPriceVibration and inTimeCycle;
  canEnter := (tradesToday < MaxTradesPerDay) and (not HasPosition());

  // ==============================
  // ENTRADA COMPRADA (REVERSÃO DE BAIXA)
  // ==============================
  if canEnter and syncCondition and revBull and atrFilter and volFilter and vwapFilter and ma21Filter then
  begin
    // Entrada a mercado no fechamento da barra do sinal
    BuyAtMarket(Qty);
    entryPrice := Close;

    // STOP
    if StopMode = 1 then
      stopPrice := Low  // atrás do candle de reversão
    else
      // metade da vibração batida
      stopPrice := entryPrice - (priceMoveAbs * 0.5);

    // ALVO
    targetPrice := entryPrice + RTarget * (entryPrice - stopPrice);

    // Envia Saídas
    SellToCoverLimit(targetPrice, Qty);
    SellToCoverStop(stopPrice, stopPrice, Qty);

    tradesToday := tradesToday + 1;
    Alert($00FF00);
  end;

  // ==============================
  // ENTRADA VENDIDA (REVERSÃO DE ALTA)
  // ==============================
  if canEnter and syncCondition and revBear and atrFilter and volFilter and vwapFilter and ma21Filter then
  begin
    SellShortAtMarket(Qty);
    entryPrice := Close;

    if StopMode = 1 then
      stopPrice := High
    else
      stopPrice := entryPrice + (priceMoveAbs * 0.5);

    targetPrice := entryPrice - RTarget * (stopPrice - entryPrice);

    BuyToCoverLimit(targetPrice, Qty);
    BuyToCoverStop(stopPrice, stopPrice, Qty);

    tradesToday := tradesToday + 1;
    Alert($FF0000);
  end;

End.
``

